# .kiloignore — Exclusions for Kilo indexing only (does not affect Git)

# VCS and metadata
.git
.hg
.svn
.git-*
*.orig

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Icon

# Dependency directories
node_modules/
.pnpm-store/
.npm/
bower_components/
vendor/
.cargo/
Cargo.lock
.pip/
.venv/
venv/
env/
.venv*/
env*/
venv*/

# Build outputs and frameworks
dist/
build/
out/
target/
bin/
obj/
release/
debug/
.storybook-out/
storybook-static/

# Java/JVM/Android
.gradle/
.gradle/
.mvn/
.mvn/wrapper/
mvnw
mvnw.cmd
*.class
*.jar
*.war
*.ear
*.iml
.idea/
**/build/
android/.gradle/
android/build/
local.properties
.cxx/
captures/

# Kotlin/Gradle caches
.kotlinc/
.kover/
.idea/modules/

# JavaScript/TypeScript toolchains
.next/
.nuxt/
.svelte-kit/
.angular/
.turbo/
.cache/
.parcel-cache/
.nyc_output/
.eslintcache
.tsbuildinfo
.yarn/
.pnp
.pnp.js

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.ipynb_checkpoints/
*.ipynb

# Go
vendor/
bin/
*.test

# Rust
target/

# Dart/Flutter
.dart_tool/
.packages
.pub-cache/
.flutter-plugins
.flutter-plugins-dependencies
.melos_tool/
pubspec.lock
# Flutter/Dart build outputs (also covered above)
build/

# iOS/macOS (if present)
Pods/
DerivedData/
*.xcworkspace
*.xcodeproj
*.xcuserdatad

# Logs and temp files
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.tmp/
tmp/
temp/
~$*
*.swp
*.swo

# Env and secrets
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.keystore
*.jks

# Large/binary assets (safe to exclude from indexing)
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.ico
*.bmp
*.tiff
*.tif
*.avif
*.mp4
*.mkv
*.webm
*.mp3
*.wav
*.ogg
*.flac
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx
*.zip
*.gz
*.bz2
*.xz
*.7z
*.rar
*.tar
*.iso

# Databases and data dumps
*.sqlite
*.sqlite3
*.db
*.mdb
*.accdb
*.sql
*.dump

# Docker and runtime
.docker/
docker-data/
**/.coverage*
coverage/
coverage-final.json

# Keep original minimal rules (already covered above, left for clarity)
node_modules
dist
build
coverage
.tmp
